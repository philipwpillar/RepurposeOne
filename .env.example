# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI (OpenAI — swap models without code changes)
OPENAI_API_KEY=sk-...
AI_PROVIDER=openai
AI_MODEL_FAST=gpt-4o-mini
AI_MODEL_STRONG=gpt-4o
AI_TEMPERATURE=0.7
AI_MAX_INPUT_CHARS=30000

# Plan limits (monthly repurpose count per tier)
PLAN_LIMIT_FREE=10
PLAN_LIMIT_CREATOR=100
PLAN_LIMIT_PRO=1000
