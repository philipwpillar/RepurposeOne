# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth (optional — email/password works without this)
# Set to "true" after enabling Google provider in Supabase dashboard
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# AI (OpenRouter — swap models without code changes)
OPENROUTER_API_KEY=sk-or-v1-...
AI_PROVIDER=openrouter
# Model tiers — see FORMAT_MODEL_TIER in lib/config.ts for per-format routing
# fast:   cheap + quick (simple/short formats)
# strong: higher quality (threads, newsletters, multi-part output)
AI_MODEL_FAST=openai/gpt-4o-mini
AI_MODEL_STRONG=openai/gpt-4o
AI_TEMPERATURE=0.7
AI_MAX_INPUT_CHARS=30000

# Plan limits (monthly successful repurposes per tier)
PLAN_LIMIT_FREE=10
PLAN_LIMIT_CREATOR=100
PLAN_LIMIT_PRO=1000

# Burst rate limit for /api/generate (per user, rolling window)
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MINUTES=10
